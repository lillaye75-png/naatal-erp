rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(tenantId) {
      return tenantId == request.auth.uid;
    }

    function belongsToTenant(tenantId) {
      return request.auth.token.tenantId == tenantId;
    }

    function belongsToTenantOrOwner(tenantId) {
      return isOwner(tenantId) || belongsToTenant(tenantId);
    }

    function hasRole(role) {
      return request.auth.token.role == role;
    }

    function isOwnerOrAdmin(tenantId) {
      return isOwner(tenantId) || hasRole('OWNER') || hasRole('ADMIN');
    }

    function isOwnerOrAdminDoc() {
      return isOwner(resource.data.tenantId) || hasRole('OWNER') || hasRole('ADMIN');
    }

    match /tenants/{tenantId} {
      allow read: if isAuthenticated() && belongsToTenantOrOwner(tenantId);
      allow write: if isAuthenticated() && belongsToTenantOrOwner(tenantId) && isOwnerOrAdmin(tenantId);
    }

    match /users/{userId} {
      allow read, write: if isAuthenticated() && (
        request.auth.uid == userId ||
        resource.data.tenantId == request.auth.token.tenantId ||
        resource.data.tenantId == request.auth.uid
      );
      allow create: if isAuthenticated() && (
        request.resource.data.tenantId == request.auth.uid ||
        request.resource.data.tenantId == request.auth.token.tenantId
      );
    }

    match /roles/{roleId} {
      allow read: if isAuthenticated() && (
        resource.data.tenantId == request.auth.uid ||
        resource.data.tenantId == request.auth.token.tenantId
      );
      allow write: if isAuthenticated() && isOwnerOrAdminDoc();
    }

    match /{collection}/{docId} {
      allow read: if isAuthenticated() && belongsToTenantOrOwner(resource.data.tenantId);
      allow create: if isAuthenticated() && belongsToTenantOrOwner(request.resource.data.tenantId);
      allow update: if isAuthenticated() && belongsToTenantOrOwner(resource.data.tenantId);
      allow delete: if isAuthenticated() && isOwnerOrAdminDoc();
    }

    match /audit_logs/{logId} {
      allow create: if isAuthenticated() && belongsToTenantOrOwner(request.resource.data.tenantId);
      allow read: if isAuthenticated() && belongsToTenantOrOwner(resource.data.tenantId);
      allow delete: if false;
    }

    match /counters/{counterId} {
      allow read, write: if isAuthenticated() && belongsToTenantOrOwner(counterId.replace('invoice_', ''));
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && belongsToTenantOrOwner(resource.data.tenantId);
      allow create: if isAuthenticated() && belongsToTenantOrOwner(request.resource.data.tenantId);
      allow update: if isAuthenticated() && belongsToTenantOrOwner(resource.data.tenantId);
      allow delete: if false;
    }
  }
}
